table Fact_Claims
	lineageTag: ecceaf77-779e-4cb7-ab2d-7f4b9aa845cf

	measure 'Total Billed Amount' = SUM(Fact_Claims[BilledAmount])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: fc991681-f4b3-4b14-bd2d-a11969ffda18

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Total Paid Amount' = SUM(Fact_Claims[PaidAmount])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 4f5192df-5169-4852-8560-0a192aeb0428

	measure 'Total A/R Amount' = [Total Billed Amount]-[Total Paid Amount]
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: c5d10ca3-e6d7-4174-8ec0-f824db7b5a71

	measure 'Net Collection Rate %' = DIVIDE([Total Paid Amount],[Total Allowed Amount])
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b3ebb5c8-802e-465d-91e1-00da2492d00f

	measure 'Total Claims Count' = COUNTROWS(Fact_Claims)
		formatString: 0
		lineageTag: 5039a6c9-247d-42aa-ba55-07d280700622

	measure 'Avg Paid Per Claim' = DIVIDE([Total Paid Amount],[Total Claims Count],0)
		lineageTag: f9cf381d-9ec6-4515-8975-a6e7cb55f062

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total final' = DISTINCTCOUNT(Fact_Claims[ClaimKey])
		formatString: 0
		lineageTag: 22f7bb1e-6e8d-4c09-af15-72f696a754e8

	measure Tb = SUM(Fact_Claims[BilledAmount])
		lineageTag: a82898e8-499d-4c98-a7bb-3ebd00047625

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Allowed Amount' = SUM(Fact_Claims[AllowedAmount])
		lineageTag: af11b965-c9ae-4518-97e3-0b545973aec0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Organizational Denial Rate %' = DIVIDE(CALCULATE(COUNT(Fact_Claims[ClaimKey]),Dim_Claims[ClaimStatus]="Denied"),COUNT(Fact_Claims[ClaimKey]))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e9af3e63-691d-4fe3-9433-fd71d6527714

	measure 'Total Denied Amount' = CALCULATE(SUM(Fact_Claims[BilledAmount]),Dim_Claims[ClaimStatus]="Denied")
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: b13d7980-a3f0-45fe-bc5f-404a66a640f6

	measure 'Denied Claim Volume' = CALCULATE(COUNT(Fact_Claims[ClaimKey]),Dim_Claims[ClaimStatus]="Denied")
		formatString: 0
		lineageTag: 94d44dc5-1283-4ac9-bd05-047ae2fafec4

	measure 'Claim Processing Cycle Time' = AVERAGEX('Fact_Claims', 'Fact_Claims'[DaysOutstanding])
		formatString: 0
		lineageTag: 58950edd-9b2a-4cfa-a8f1-5b77709650f7

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Clean Claim Rate %' = ```
			
			DIVIDE(
			    CALCULATE(COUNT('Fact_Claims'[ClaimKey]), 'Dim_Claims'[ClaimStatus] IN {"Paid", "Approved"}),
			    COUNT('Fact_Claims'[ClaimKey]),
			    0
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 52b1f603-422b-46ee-82c4-414a5f62eab4

	measure '90+ Day Risk %' = ```
			
			DIVIDE(
			    CALCULATE(SUM('Fact_Claims'[BilledAmount]), 'Fact_Claims'[Aging Bucket] = "90+ Days"),
			    SUM('Fact_Claims'[BilledAmount]),
			    0
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 8ff3f963-9587-4a44-8821-3cb32646cd25

	measure 'Last Refreshed' = ```
			"Data as of: " & FORMAT(NOW(), "MM/DD/YYYY HH:mm AM/PM")
			
			```
		lineageTag: 56c983d5-67fa-4d36-8525-a04bc8302358

