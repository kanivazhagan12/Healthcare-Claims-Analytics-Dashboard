	column 'Aging Bucket' =
			
			SWITCH(TRUE(),
			    'Fact_Claims'[DaysOutstanding] <= 30, "0-30 Days",
			    'Fact_Claims'[DaysOutstanding] <= 60, "31-60 Days",
			    'Fact_Claims'[DaysOutstanding] <= 90, "61-90 Days",
			    "90+ Days"
			)
		lineageTag: 2ff4a5f2-982e-4768-bc2c-da806445506f
		summarizeBy: none
		sortByColumn: 'Aging Sort'

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column 'Aging Sort' = ```
			
			SWITCH(TRUE(),
			    'Fact_Claims'[DaysOutstanding] <= 30, 1,
			    'Fact_Claims'[DaysOutstanding] <= 60, 2,
			    'Fact_Claims'[DaysOutstanding] <= 90, 3,
			    4
			)
			
			```
		formatString: 0
		lineageTag: 7087d6db-4e01-4d0b-8e71-5720f86bd051
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

