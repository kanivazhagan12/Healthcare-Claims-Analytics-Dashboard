	column 'Denial Label' = IF(Dim_Claims[DenialCode]="N/A","Paid/Pended",Dim_Claims[DenialCode]&"-"&Dim_Claims[DenialReason])
		lineageTag: 03eccb41-32a6-4d25-839f-d9d41d890d90
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Denial Category' = ```
			
			SWITCH( TRUE(),
			    Dim_Claims[DenialCode] = "N/A", "Paid/Pended",    
			    Dim_Claims[DenialCode] IN {"CO-18", "CO-197", "CO-29", "CO-97"}, "Controllable",    
			    Dim_Claims[DenialCode] IN {"CO-22", "CO-27"}, "Uncontrollable",
			    "Uncontrollable"
			)
			
			```
		lineageTag: dfa23438-52d5-4b6f-87c2-05b60867168d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

